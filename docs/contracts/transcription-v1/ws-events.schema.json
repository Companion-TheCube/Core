{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.4thecube.com/transcription/v1/ws-events.schema.json",
  "title": "Transcription V1 WebSocket Events",
  "description": "Server-to-client JSON events for remote transcription v1. Client-to-server audio is binary PCM16LE mono 16kHz frames.",
  "oneOf": [
    { "$ref": "#/$defs/session_ready" },
    { "$ref": "#/$defs/final" },
    { "$ref": "#/$defs/error" }
  ],
  "$defs": {
    "session_ready": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id", "audio_format"],
      "properties": {
        "type": { "const": "session_ready" },
        "session_id": { "type": "string", "minLength": 1 },
        "audio_format": {
          "type": "object",
          "additionalProperties": false,
          "required": ["encoding", "sample_rate_hz", "channels"],
          "properties": {
            "encoding": { "const": "pcm16le" },
            "sample_rate_hz": { "const": 16000 },
            "channels": { "const": 1 }
          }
        },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "final": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id", "transcript", "is_final"],
      "properties": {
        "type": { "const": "final" },
        "session_id": { "type": "string", "minLength": 1 },
        "transcript": { "type": "string" },
        "is_final": { "const": true },
        "language": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "audio_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "session_id", "error"],
      "properties": {
        "type": { "const": "error" },
        "session_id": { "type": "string", "minLength": 1 },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message", "retryable"],
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "INVALID_AUDIO_CHUNK",
                "WS_TOKEN_INVALID",
                "SESSION_EXPIRED",
                "SESSION_NOT_FOUND",
                "RATE_LIMITED",
                "INTERNAL_ERROR"
              ]
            },
            "message": { "type": "string" },
            "retryable": { "type": "boolean" }
          }
        }
      }
    }
  }
}
