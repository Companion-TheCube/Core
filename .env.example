# Copy this file to `.env` and adjust values as needed.

# HTTP server default binding (used by CubeCore runtime)
HTTP_ADDRESS=0.0.0.0
HTTP_PORT=55280

# IPC (UNIX socket) path for CubeCore runtime
IPC_SOCKET_PATH=/run/thecube/cube.sock

# Host hardware safety switches. Set these to 0 on laptop/dev machines to
# prevent CORE from talking to real hardware buses.
# HARDWARE_I2C_ENABLED=0
# HARDWARE_SPI_ENABLED=0
# ACCEL_I2C_DEVICE=/dev/i2c-1
# ACCEL_I2C_ADDRESS=0x68
# ACCEL_I2C_10BIT=0

# Test overrides (used by integration tests)
HTTP_PORT_TEST=55281
IPC_SOCKET_PATH_TEST=/run/thecube/test_ipc.sock

# Remote transcription service (required for remote-only STT path)
REMOTE_TRANSCRIPTION_BASE_URL=https://api.4thecube.com
REMOTE_TRANSCRIPTION_API_KEY=replace-with-api-key

# Optional auth and runtime tuning
# REMOTE_AUTH_KEY=replace-with-bearer-token-if-used
# DEVICE_SERIAL_NUMBER=your-device-serial
# REMOTE_TRANSCRIPTION_WAIT_FINAL_MS=15000
# REMOTE_TRANSCRIPTION_MAX_SESSION_MS=15000
# REMOTE_TRANSCRIPTION_WAKEWORD_VAD_DELAY_MS=600
# REMOTE_TRANSCRIPTION_NO_SPEECH_TIMEOUT_MS=5000
# REMOTE_TRANSCRIPTION_SILENCE_TIMEOUT_MS=700
# REMOTE_TRANSCRIPTION_SPEECH_MEAN_ABS_THRESHOLD=350
# REMOTE_TRANSCRIPTION_SPEECH_PEAK_THRESHOLD=1200

# Optional Silero VAD tuning
# SILERO_VAD_ENABLED=1
# SILERO_VAD_MODEL_PATH=
# SILERO_VAD_THRESHOLD=0.5
# SILERO_VAD_RELEASE_DELTA=0.15
# SILERO_VAD_WINDOW_MS=32
# SILERO_VAD_MIN_SILENCE_MS=160
# SILERO_VAD_INTRA_THREADS=1
# SILERO_VAD_INTER_THREADS=1

# Optional example metadata
# BUILD_AUTHOR=Your Name
